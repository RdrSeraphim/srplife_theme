{
    "name": "srplife",
    "description": "A CDE/Solaris-inspired retro theme for Hugo.",
    "demo": "https://srp.life",
    "version": "3.0.0",
    "scripts": {
        "dev": "cd exampleSite && hugo server --themesDir ../.. --port 8787 --buildDrafts --disableFastRender",
        "build": "cd exampleSite && hugo --themesDir ../.. --minify"
    },
    "license": "MIT",
    "author": {
        "name": "Seraphim Pardee",
        "email": "me@srp.life",
        "url": "https://srp.life"
    },
    "keywords": [
        "hugo",
        "theme",
        "hugo-theme",
        "retro",
        "cde",
        "solaris"
    ],
    "devDependencies": {
        "autoprefixer": "^10.4.22",
        "cssnano": "^7.1.2",
        "lucide-static": "^1.24.0",
        "postcss": "^8.5.6",
        "postcss-cli": "^11.0.1",
        "postcss-import": "^16.1.1",
        "postcss-nested": "^7.0.2",
        "prettier": "^3.9.5",
        "prettier-plugin-toml": "^2.0.6",
        "simple-icons": "^12.4.0"
    }
}
